{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "hangulpy",
  "description": "A Python library for Korean language processing.",
  "colors": {
    "primary": "#0f766e",
    "light": "#14b8a6",
    "dark": "#0f766e"
  },
  "appearance": {
    "default": "light"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/gaon12/hangulpy"
      },
      {
        "label": "PyPI",
        "href": "https://pypi.org/project/hangulpy/"
      }
    ]
  },
  "search": {
    "prompt": "함수 이름이나 기능으로 검색"
  },
  "navigation": {
    "groups": [
      {
        "group": "소개",
        "pages": [
          "docs/index",
          "docs/installation",
          "docs/quickstart",
          "docs/api/overview"
        ]
      },
      {
        "group": "검색과 매칭",
        "pages": [
          "docs/api/search/get-chosung",
          "docs/api/search/hangul-contains",
          "docs/api/search/hangul-search",
          "docs/api/search/hangul-searcher",
          "docs/api/search/match-hangul-pattern"
        ]
      },
      {
        "group": "조사와 받침",
        "pages": [
          "docs/api/particles/josa",
          "docs/api/particles/batchim",
          "docs/api/particles/jarip-noun"
        ]
      },
      {
        "group": "한글 판별과 추출",
        "pages": [
          "docs/api/properties/is-hangul",
          "docs/api/properties/syllable-types",
          "docs/api/properties/jamo-roles",
          "docs/api/properties/get-components"
        ]
      },
      {
        "group": "분해와 조합",
        "pages": [
          "docs/api/assembly/decompose-hangul-string",
          "docs/api/assembly/split-hangul-string",
          "docs/api/assembly/split-syllables",
          "docs/api/assembly/join-jamos",
          "docs/api/assembly/hangul-syllable"
        ]
      },
      {
        "group": "변환과 정렬",
        "pages": [
          "docs/api/conversions/number-to-hangul",
          "docs/api/conversions/hangul-to-number",
          "docs/api/conversions/romanize",
          "docs/api/conversions/keyboard",
          "docs/api/conversions/sort-hangul"
        ]
      },
      {
        "group": "참고 자료",
        "pages": [
          "docs/implemented-features",
          "docs/releases/v1-3-1"
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/gaon12/hangulpy"
    }
  }
}
